# ============================================================
# SKU Code Generator - 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Supabase 控制台 > Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-anon-public-key
# 注：表名固定为 sku_cost，无需配置

# ── 飞书（Lark）────────────────────────────────────────────────
# 飞书开放平台 > 创建企业自建应用 > 凭证与基础信息
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书电子表格 Token（从 URL 中获取）
# 例：https://xxx.feishu.cn/sheets/shtcnXXXXXXXXXX → shtcnXXXXXXXXXX
FEISHU_SPREADSHEET_TOKEN=shtcnXXXXXXXXXX

# 工作表名称（右键标签页查看），默认 Sheet1
FEISHU_SHEET_ID=Sheet1
